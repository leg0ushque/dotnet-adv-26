{
  "realm": "Ecommerce",
  "enabled": true,
  "roles": {
    "realm": [
      { "name": "Manager" },
      { "name": "Store customer" }
    ]
  },
  "users": [
    {
      "username": "manager1",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "managerpass" }],
      "realmRoles": ["Manager"]
    },
    {
      "username": "customer1",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "customerpass" }],
      "realmRoles": ["Store customer"]
    }
  ],
  "clients": [
    {
      "clientId": "catalog-service",
      "enabled": true,
      "publicClient": false,
      "secret": "catalog-secret",
      "redirectUris": ["http://localhost:5000/*"]
    },
    {
      "clientId": "cart-service",
      "enabled": true,
      "publicClient": false,
      "secret": "cart-secret",
      "redirectUris": ["http://localhost:5001/*"]
    }
  ]
}