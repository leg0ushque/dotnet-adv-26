        <mxCell id="yeFEpm4IVjwCl-uXW5aX-81" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;" value="Database" vertex="1">
          <mxGeometry height="80" width="60" x="300" y="282" as="geometry" />
        </mxCell>
        <mxCell id="yeFEpm4IVjwCl-uXW5aX-83" parent="1" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;rounded=0;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" value="&lt;div&gt;Provided architecture is clearly database-centric with multi-layered components.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;-- all components have DAL, BLL, PL&lt;/div&gt;&lt;div&gt;-- all the requests from components are sent directly to DB without any inter-communication.&lt;/div&gt;&lt;div&gt;-- no common event bus or API (gateway) is provided&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;It&#39;s&amp;nbsp;easy to run, deploy and test - all the requests are direct.&lt;br&gt;&lt;br&gt;&lt;/div&gt;The drawbacks I see&lt;br&gt;&lt;br&gt;-- overloaded DB, may contain extra business logic&lt;div&gt;-- individual authentication in every service&lt;/div&gt;&lt;div&gt;-- clients are overloaded with logic that may be contained on server (API) side.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="400" width="260" x="560" y="40" as="geometry" />
        </mxCell>
        <mxCell id="wAqzE6NGV6aaY-ep7Fwl-1" parent="1" style="verticalLabelPosition=bottom;sketch=0;aspect=fixed;html=1;verticalAlign=top;strokeColor=none;align=center;outlineConnect=0;shape=mxgraph.citrix.reporting;" value="3rd Party&lt;div&gt;Reporting Service&lt;/div&gt;" vertex="1">
