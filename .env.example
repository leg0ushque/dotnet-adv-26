# SQL Server
SQLSERVER_SA_PASSWORD=yourStrongPasswordHere

# MongoDB
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=yourMongoRootPassword

# Mongo Express
ME_CONFIG_BASICAUTH_USERNAME=mongoexpressuser
ME_CONFIG_BASICAUTH_PASSWORD=yourMongoExpressPassword

# RabbitMQ
