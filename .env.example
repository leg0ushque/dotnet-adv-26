RABBITMQ_DEFAULT_PASS=yourRabbitMQPassword

# Keycloak
KC_DBNAME=keycloakdb
KC_DB_USERNAME=username
KC_DB_PASSWORD=yourStrongPasswordHere
KEYCLOAK_ADMIN_PASSWORD=yourKeycloakAdminPassword